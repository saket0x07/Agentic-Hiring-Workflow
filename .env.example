# ==========================================
# Agentic Hiring Workflow Environment Setup
# ==========================================

# LLM API Keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
GOOGLE_API_KEY=AIzaSy-your-google-api-key-here
GROQ_API_KEY=gsk_your_groq_api_key_here

# LLM Configuration
DEFAULT_LLM_MODEL=gpt-4o-mini
TEMPERATURE=0.2

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./hiring_workflow.db

# Email / Notification SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=hiring-team@example.com
SMTP_PASSWORD=your_app_password_here
SENDER_EMAIL=hiring-team@example.com
